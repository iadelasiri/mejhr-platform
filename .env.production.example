# ============================================================
# Mejhr Platform — Production Environment Variables
#
# Copy this file to .env on the production server:
#   cp .env.production.example .env
#
# Fill in every value marked <CHANGE>.
# Never commit .env to version control.
#
# Generate secrets with:
#   python -c "import secrets; print(secrets.token_hex(64))"
# ============================================================

# ── App ─────────────────────────────────────────────────────
APP_ENV=production
APP_NAME=Mejhr
APP_VERSION=0.1.0
DEBUG=false

# Your production domain (used by Nginx and CORS)
DOMAIN=mejhr.example.sa

# ── Database ─────────────────────────────────────────────────
POSTGRES_DB=mejhr_db
POSTGRES_USER=mejhr_user
POSTGRES_PASSWORD=<CHANGE: strong random password>

# These are derived from the vars above — update if you change host/port.
DATABASE_URL=postgresql+asyncpg://mejhr_user:<CHANGE: same password>@db:5432/mejhr_db
DATABASE_URL_SYNC=postgresql://mejhr_user:<CHANGE: same password>@db:5432/mejhr_db

# ── Redis ────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# ── Security ─────────────────────────────────────────────────
# 64-character random hex. Generate: python -c "import secrets; print(secrets.token_hex(64))"
SECRET_KEY=<CHANGE: 64-char random hex string>
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── CORS ─────────────────────────────────────────────────────
CORS_ORIGINS=["https://mejhr.example.sa"]

# ── Data integrity ───────────────────────────────────────────
# MUST be false in production. Changing this to true will cause startup failure.
ENABLE_SAMPLE_DATA=false

# ── Storage ──────────────────────────────────────────────────
# Absolute path inside the container. Matches the volume mount in docker-compose.prod.yml.
STORAGE_PATH=/storage

# ── Saudi Exchange ───────────────────────────────────────────
# Base URL — do not change unless the domain changes.
SAUDI_EXCHANGE_BASE_URL=https://www.saudiexchange.sa

# Timeout per request in seconds.
SAUDI_EXCHANGE_TIMEOUT=30

# Network-error retries (does not retry on HTTP 4xx/5xx).
SAUDI_EXCHANGE_RETRY_ATTEMPTS=3

# Seconds between retry attempts.
SAUDI_EXCHANGE_RETRY_SLEEP=2.0

# Optional HTTP/HTTPS proxy (Saudi/GCC proxy if the server is geo-blocked).
# Example: SAUDI_EXCHANGE_PROXY=http://proxy.sa.example.com:8080
# Leave blank if the server is in Saudi Arabia or GCC and reaches SE directly.
# SAUDI_EXCHANGE_PROXY=

# Optional API key if Saudi Exchange issues one via an official data agreement.
# Leave blank until/unless an official API key is obtained.
# SAUDI_EXCHANGE_API_KEY=

# User-Agent sent with all Saudi Exchange requests.
SAUDI_EXCHANGE_USER_AGENT=Mozilla/5.0 (compatible; MejhrDataBot/1.0; official-data-collection)

# IMPORTANT: This path must be verified from the GCC server.
# Default is the All Shares portal page (returns HTML, not JSON).
# Step 1: Deploy to GCC server.
# Step 2: Run: docker compose exec backend python -m app.pipeline.exchange.endpoint_probe
# Step 3: Update this to the confirmed JSON API path.
SAUDI_EXCHANGE_COMPANIES_PATH=/wps/portal/saudiexchange/newsandreports/market-data/trading-data/all-shares

# Additional candidate paths to probe (JSON array). Leave empty initially.
# Example after finding candidates via browser DevTools:
# SAUDI_EXCHANGE_ENDPOINT_CANDIDATES=["/api/market/companies","/data/v1/listed-companies"]
SAUDI_EXCHANGE_ENDPOINT_CANDIDATES=[]

# ── Frontend ─────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=https://mejhr.example.sa
NEXT_PUBLIC_APP_NAME=Mejhr
