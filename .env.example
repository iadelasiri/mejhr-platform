# ============================================================
# Mejhr Platform — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ============================================================

# --- App ---
APP_ENV=development    # "development" | "production" | "test"
DEBUG=true
# IMPORTANT: Must be false in production. Startup fails if true + APP_ENV=production.
ENABLE_SAMPLE_DATA=false
CORS_ORIGINS=["http://localhost:3000"]

# --- PostgreSQL (LOCAL DOCKER — development fallback) ---
# Used only by the local docker-compose db service.
# Not needed when connecting to Supabase.
POSTGRES_DB=mejhr_db
POSTGRES_USER=mejhr_user
POSTGRES_PASSWORD=change-me-in-production

# ── Option A: Local Docker PostgreSQL (default for development) ──────────
DATABASE_URL=postgresql+asyncpg://mejhr_user:change-me-in-production@db:5432/mejhr_db
DATABASE_URL_SYNC=postgresql://mejhr_user:change-me-in-production@db:5432/mejhr_db

# ── Option B: Supabase PostgreSQL ───────────────────────────────────────
# Get these from: Supabase Dashboard → Project Settings → Database
#
# DATABASE_URL uses the Transaction Pooler (port 6543) — optimised for
# async connections (FastAPI / asyncpg). The pool_pre_ping handles dropped
# connections; prepared_statement_cache_size=0 is set automatically in
# database.py when "pooler.supabase.com" is detected in the URL.
#
# DATABASE_URL_SYNC uses the Direct Connection (port 5432) — required for
# Alembic migrations which need a stable, persistent session.
# Never run Alembic against the transaction pooler (port 6543).
#
# DATABASE_URL=postgresql+asyncpg://postgres.[PROJECT_REF]:[DB_PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?ssl=require
# DATABASE_URL_SYNC=postgresql://postgres:[DB_PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres?sslmode=require

# --- Redis ---
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# --- Security ---
# Generate: python -c "import secrets; print(secrets.token_hex(64))"
SECRET_KEY=change-me-in-production-use-64-char-random-hex-string

# --- Storage ---
STORAGE_PATH=/storage

# --- Saudi Exchange (Phase 2A) ---
SAUDI_EXCHANGE_BASE_URL=https://www.saudiexchange.sa
SAUDI_EXCHANGE_TIMEOUT=30
SAUDI_EXCHANGE_RETRY_ATTEMPTS=3
SAUDI_EXCHANGE_RETRY_SLEEP=2.0
# SAUDI_EXCHANGE_PROXY=
# SAUDI_EXCHANGE_API_KEY=
SAUDI_EXCHANGE_USER_AGENT=Mozilla/5.0 (compatible; MejhrDataBot/1.0; official-data-collection)
SAUDI_EXCHANGE_COMPANIES_PATH=/wps/portal/saudiexchange/newsandreports/market-data/trading-data/all-shares

# --- Frontend ---
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_APP_NAME=Mejhr
